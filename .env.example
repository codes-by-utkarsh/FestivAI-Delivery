# ============================================================
# FestivAI Delivery - Environment Configuration
# Copy this file to .env and fill in the real values
# ============================================================

# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=super_secret_development_key_123!

# ── Google Sheets Database ────────────────────────────────────
# 1. Create a Google Sheet with tabs: Users, Customers, Festivals, Video Logs
# 2. Share it with your Service Account email (from credentials.json)
# 3. Get the Sheet ID from the URL: .../spreadsheets/d/SHEET_ID/edit
SPREADSHEET_ID=your_google_spreadsheet_id_here

# ── Google Cloud Service Account ──────────────────────────────
# Path to your Service Account JSON key file (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_JSON=credentials.json

# ── Meta WhatsApp Cloud API ───────────────────────────────────
# Get these from your Meta Developer App at: https://developers.facebook.com/
# - WHATSAPP_TOKEN: Your Permanent or Temporary Access Token
# - WHATSAPP_API_URL: https://graph.facebook.com/v25.0/YOUR_PHONE_NUMBER_ID/messages
#   Replace YOUR_PHONE_NUMBER_ID with the numeric Phone Number ID from your Meta App
WHATSAPP_TOKEN=your_meta_whatsapp_access_token_here
WHATSAPP_API_URL=https://graph.facebook.com/v25.0/YOUR_PHONE_NUMBER_ID/messages

# ── Default Admin Account ─────────────────────────────────────
# The first time the app runs on an EMPTY Google Sheet, it seeds this admin:
#   Email: admin@festivai.com
#   Password: Admin@1234
# If your sheet already has a user (e.g. admin@example.com / adminpassword123)
# from a previous run, use that to log in and change it from the Users tab.
