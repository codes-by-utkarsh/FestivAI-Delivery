# Security Configuration
# Generate a secure random string for production (e.g., openssl rand -hex 32)
JWT_SECRET=super_secret_development_key_123!

# Google Sheets Database
# 1. Create a Google Sheet with tabs: Users, Customers, Festivals, Video Logs
# 2. Get the ID from the URL: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
SPREADSHEET_ID=14rgOlUTyz5c-K5O36P7ygZABqmuZOgmHmMPEaSDVIxQ

# Google Cloud Service Account
# Path to your downloaded Service Account JSON key
GOOGLE_CREDENTIALS_JSON=credentials.json

# Meta WhatsApp Cloud API Configuration
# Get these from your Meta Developer App Dashboard
WHATSAPP_TOKEN=your_meta_temporary_or_permanent_token_here
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/YOUR_PHONE_NUMBER_ID/messages
